# Copy this file to .env and fill only the channels you enable in config.json.

# Telegram
JOB_SCANNER_TELEGRAM_BOT_TOKEN=
JOB_SCANNER_TELEGRAM_CHAT_ID=

# Email / SMTP
JOB_SCANNER_SMTP_HOST=smtp.gmail.com
JOB_SCANNER_SMTP_PORT=587
JOB_SCANNER_SMTP_USERNAME=
JOB_SCANNER_SMTP_PASSWORD=
JOB_SCANNER_EMAIL_FROM=
JOB_SCANNER_EMAIL_TO=

# WhatsApp through Twilio
JOB_SCANNER_TWILIO_ACCOUNT_SID=
JOB_SCANNER_TWILIO_AUTH_TOKEN=
JOB_SCANNER_TWILIO_FROM=whatsapp:+14155238886
JOB_SCANNER_TWILIO_TO=whatsapp:+1YOURNUMBER
